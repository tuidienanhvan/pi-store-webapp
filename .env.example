# Frontend fallback (optional for local testing)
VITE_LEAD_API_URL=/api/lead

# Pi Backend API base URL (FastAPI) — used by admin + user dashboards
# Local:       http://localhost:8000
# Staging:     https://api.staging.piwebagency.com
# Production:  https://api.piwebagency.com
VITE_PI_API_URL=http://localhost:8000

# Mock auth mode — set to 1 to bypass backend (for UI preview).
# Login with any password. Email starting with "admin" → admin role.
# NEVER ship to production.
VITE_MOCK_AUTH=0

# Serverless proxy env (Vercel project settings)
N8N_WEBHOOK_URL=
N8N_SHARED_SECRET=
LEAD_SOURCE_NAME=pi-storefront

# Catalog sync env (optional overrides)
# WP_CONTENT_DIR=C:/path/to/wp-content
# WP_PLUGINS_DIR=C:/path/to/wp-content/plugins
# WP_THEMES_DIR=C:/path/to/wp-content/themes
# STORE_THEME_SLUG=saigonhouse-theme
# STORE_BASE_URL=https://store.pi-ecosystem.com

