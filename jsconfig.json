{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["src/*"],
      "@admin/*": ["admin/*"],
      "@shared/*": ["shared/*"],
      "@pi-ui": ["shared"],
      "@pi-ui/*": ["shared/*"]
    }
  },
  "exclude": ["node_modules", "build"]
}
